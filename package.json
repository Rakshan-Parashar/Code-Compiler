{
  "name": "zenith-ide",
  "version": "3.0.0",
  "description": "Zenith IDE – Ultimate Hybrid Code Execution Environment",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5174 && electron .\"",
    "build": "vite build && electron-builder",
    "electron": "electron ."
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "vite": "^5.0.10",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@xterm/addon-fit": "^0.8.0",
    "@xterm/addon-web-links": "^0.9.0",
    "@xterm/xterm": "^5.3.0",
    "monaco-editor": "^0.45.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "build": {
    "appId": "com.zenith.ide",
    "productName": "Zenith IDE",
    "directories": { "output": "dist-electron" },
    "files": ["dist/**/*", "src/main/**/*"],
    "mac":   { "category": "public.app-category.developer-tools" },
    "win":   { "target": "nsis" },
    "linux": { "target": "AppImage" }
  }
}