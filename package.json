{
  "name": "atmos-ide",
  "version": "1.0.0",
  "description": "Atmos IDE – Ultimate Hybrid Code Execution Environment",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \".venv\\\\Scripts\\\\python -m uvicorn backend.main:app --reload\" \"vite\" \"wait-on http://localhost:5174 && electron .\"",
    "build": "vite build && electron-builder",
    "electron": "electron ."
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "vite": "^5.0.10",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.3.0",
    "firebase": "^10.8.0",
    "monaco-editor": "^0.45.0",
    "node-pty": "^1.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "build": {
    "appId": "com.atmos.ide",
    "productName": "Atmos IDE",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
